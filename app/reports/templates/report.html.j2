<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  <style>
    body { color: #172033; background: #f5f7fb; font: 16px/1.65 system-ui, sans-serif; margin: 0; }
    main { max-width: 980px; margin: 32px auto; background: white; padding: 40px 48px; border-radius: 14px; box-shadow: 0 8px 30px #1b2a4a12; }
    h1, h2, h3 { color: #102043; line-height: 1.25; }
    h2 { border-top: 1px solid #e4e9f2; padding-top: 24px; margin-top: 32px; }
    blockquote { border-left: 4px solid #4f67d8; margin: 18px 0; padding: 8px 16px; background: #f3f5ff; }
    table { border-collapse: collapse; width: 100%; display: block; overflow-x: auto; }
    th, td { border: 1px solid #dce2ec; padding: 8px 10px; text-align: left; }
    th { background: #eef2f8; }
    a { color: #3655c6; }
    .replay { background: #fff3cd; border: 1px solid #f1d58a; padding: 10px 14px; border-radius: 8px; }
  </style>
</head>
<body>
  <main>
    {% if is_replay %}<div class="replay">Synthetic Replay Demo — not current news.</div>{% endif %}
    {{ content | safe }}
  </main>
</body>
</html>

